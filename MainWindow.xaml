<Window x:Class="ShapeShootingGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShapeShootingGame"
        mc:Ignorable="d"
        Title="Shape Shooter" Height="600" Width="1000"
        KeyDown="Window_KeyDown" Focusable="True">  
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"></RowDefinition>
			<RowDefinition Height="50"></RowDefinition>
		</Grid.RowDefinitions>

		<Canvas Name="ShapesCanvas" Grid.Row="0" Background="Black"
                MouseDown="ShapesCanvas_MouseDown"
                MouseUp="ShapesCanvas_MouseUp"
                MouseMove="ShapesCanvas_MouseMove"></Canvas>

		<WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
			<Button Margin="10" Width="70" Name="CircleBtn" Click="ShapeBtn_Click">Circle</Button>
			<Button Margin="10" Width="70" Name="RectangleBtn" Click="ShapeBtn_Click">Rectangle</Button>
			<Button Margin="10" Width="70" Name="TriangleBtn" Click="ShapeBtn_Click">Triangle</Button>
			<Button Margin="10" Width="60" Name="StepButton" Click="StepButton_Click">Step</Button>
			<Button Margin="10" Width="60" Name="PlayBtn" Click="PlayBtn_Click">Play</Button>
			<Button Margin="10" Width="60" Name="StopBtn" Click="StopBtn_Click">Stop</Button>
			<Button Margin="10" Width="120" Name="ModeBtn" Click="ModeBtn_Click">Weapon: Rifle</Button>
		</WrapPanel>
	</Grid>
</Window>